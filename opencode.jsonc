
{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/minimax-m2.7",
  "small_model": "opencode-go/qwen3.5-plus",
  "default_agent": "build",
  "share": "disabled",
  "formatter": true,
  "lsp": true,
  "snapshot": true,
  "autoupdate": "notify",
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "README.md",
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      "out/**",
      ".next/**",
      ".nuxt/**",
      "coverage/**",
      ".turbo/**",
      ".cache/**",
      ".pytest_cache/**",
      "__pycache__/**",
      ".venv/**",
      "venv/**",
      "target/**",
      "tmp/**",
      "logs/**",
      "*.log"
    ]
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "id_rsa": "deny",
      "id_ed25519": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls": "allow",
      "ls *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "sed *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git grep*": "allow",
      "git commit*": "ask",
      "git push*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",
      "git checkout*": "ask",
      "rm *": "ask",
      "rm -rf *": "deny",
      "sudo *": "deny"
    },
    "external_directory": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "todowrite": "allow",
    "skill": "allow"
  },
  "provider": {
    "opencode-go": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 60000
      }
    },
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "model": "opencode-go/minimax-m2.7",
      "permission": {
        "edit": "allow"
      }
    },
    "quickfix": {
      "model": "opencode-go/deepseek-v4-flash",
      "permission": {
        "edit": "allow"
      }
    },
    "debug": {
      "model": "opencode-go/deepseek-v4-pro",
      "permission": {
        "edit": "allow"
      }
    },
    "hard-code": {
      "model": "opencode-go/deepseek-v4-pro",
      "permission": {
        "edit": "allow"
      }
    },
    "long-refactor": {
      "model": "opencode-go/deepseek-v4-pro",
      "permission": {
        "edit": "allow"
      }
    },
    "test-writer": {
      "model": "opencode-go/minimax-m2.7",
      "permission": {
        "edit": "allow"
      }
    },
    "docs": {
      "model": "opencode-go/deepseek-v4-flash",
      "permission": {
        "edit": "allow"
      }
    },
    "review": {
      "model": "openai/gpt-5.5"
    },
    "write-commit": {
      "description": "Drafts a conventional commit message from the current git diff. Returns a commit subject, body explaining why, and test notes. Does not edit files or run git commit.",
      "mode": "subagent",
      "model": "opencode-go/qwen3.5-plus",
      "permission": {
        "edit": "deny",
        "bash": {
          "git status*": "allow",
          "git diff*": "allow"
        }
      }
    }
  }
}
