
{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/minimax-m2.7",
  "small_model": "opencode-go/qwen3.5-plus",
  "default_agent": "general",
  "share": "disabled",
  "formatter": true,
  "lsp": true,
  "snapshot": true,
  "autoupdate": "notify",
  "instructions": [
    "AGENTS.md",
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000,
    "tail_turns": 4
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      "out/**",
      ".next/**",
      ".nuxt/**",
      "coverage/**",
      ".turbo/**",
      ".cache/**",
      ".pytest_cache/**",
      "__pycache__/**",
      ".venv/**",
      "venv/**",
      "target/**",
      "tmp/**",
      "logs/**",
      "*.log"
    ]
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "id_rsa": "deny",
      "id_ed25519": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls": "allow",
      "ls *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "tr": "allow",
      "tr *": "allow",
      "sort": "allow",
      "sort *": "allow",
      "diff": "allow",
      "diff *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "sed": "allow",
      "sed *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git grep*": "allow",
      "git commit*": "ask",
      "git push*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",
      "git checkout*": "ask",
      "rm *": "ask",
      "rm -rf *": "deny",
      "sudo *": "deny"
    },
    "external_directory": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "todowrite": "allow",
    "skill": "allow"
  },
  "tool_output": {
    "max_bytes": 30000,
    "max_lines": 1000
  },
  "provider": {
    "opencode-go": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 60000
      }
    },
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  },
  "agent": {
    "general": {
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "primary",
      "permission": {
        "task": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "plan": {
      "model": "opencode-go/mimo-v2.5-pro",
      "mode": "primary",
      "permission": {
        "task": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "build": {
      "model": "opencode-go/mimo-v2.5",
      "mode": "primary",
      "permission": {
        "edit": "allow"
      }
    },
    "review": {
      "model": "openai/gpt-5.5",
      "mode": "subagent",
      "permission": {
        "edit": "deny"
      }
    },
    "explore": {
      "model": "openai/gpt-5.5",
      "mode": "subagent",
      "permission": {
        "webfetch": "allow",
        "websearch": "allow",
        "edit": "deny"
      }
    },
    "debug": {
      "model": "openai/gpt-5.5",
      "mode": "subagent",
      "permission": {
        "webfetch": "allow",
        "websearch": "allow",
        "edit": "deny"
      }
    },
    "refactor": {
      "model": "openai/gpt-5.5",
      "mode": "subagent",
      "permission": {
        "edit": "deny"
      }
    },
    "test": {
      "model": "openai/gpt-5.5",
      "mode": "subagent",
      "permission": {
        "edit": "deny"
      }
    },
    "explain": {
      "model": "openai/gpt-5.5",
      "mode": "subagent",
      "permission": {
        "webfetch": "allow",
        "websearch": "allow",
        "edit": "deny"
      }
    }
  }
}
